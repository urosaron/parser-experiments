# MinIO credentials — copy this file to .env and fill in your values.
# The .env file is gitignored; never commit real credentials.
MINIO_ROOT_USER=holodeck
MINIO_ROOT_PASSWORD=holodeck123

# Base URL for asset objects served by MinIO.
# Change this to match the machine you are running on:
#   Laptop  : http://127.0.0.1:9000
#   Company PC (via LAN): http://<LAN-IP>:9000
ASSET_BASE_URL=http://127.0.0.1:9000
